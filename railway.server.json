{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun run --filter=@spotify-roadtrip/server build",
    "watchPatterns": ["/packages/server/**", "/package.json", "/bun.lock"]
  },
  "deploy": {
    "startCommand": "bun run --filter=@spotify-roadtrip/server start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "sleepApplication": true,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
