    "test": "bun test",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "better-auth": "^1.4.18",
    "hono": "^4.6.0",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8"
  }
}
